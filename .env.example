# ─── Required ────────────────────────────────────────────────────────────────
# Path to a Solana wallet keypair JSON file (the Solana CLI / Phantom export format:
# a JSON array of 64 bytes). NEVER commit this file. Chmod 0600.
WALLET_PATH=./wallet.json

# Solana mainnet RPC. Use your own provider for production (Helius / QuickNode /
# Triton). The public endpoint is heavily rate-limited and will not survive a DCA loop.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# DCA parameters.
DCA_SYMBOL=TSLAx                 # one of TSLAx | NVDAx | AAPLx | SPYx | MSTRx | MSFTx
DCA_USDC_PER_BUY=10              # human-readable USDC amount per tick (not micro)
DCA_INTERVAL_MINUTES=30          # cadence between ticks

# ─── Optional ────────────────────────────────────────────────────────────────
# Slippage tolerance for the Jupiter quote, in basis points (100 = 1%).
SLIPPAGE_BPS=100

# All-in cost cap (spread + price impact + fees), in basis points. The agent
# refuses to execute if the quoted all-in cost exceeds this. 150 bps = 1.5%.
MAX_COST_BPS=150

# Headless Oracle MIC to gate on. XNYS = NYSE; XNAS = Nasdaq. xStocks underlyings
# trade on both — XNYS is a reasonable default because NYSE and Nasdaq share
# session windows in normal conditions, but if you want strict-per-listing-venue
# protection, run two agents.
HEADLESS_ORACLE_MIC=XNYS

# If set, the gate calls /v5/status (production key path); otherwise /v5/demo
# (keyless, rate-limited but free, identical signed receipt shape).
# HEADLESS_ORACLE_API_KEY=

# Soft mode: when true, treat network errors (KEY_FETCH_FAILED, fetch errors)
# as PASS-THROUGH rather than halt. NEVER use this in production unless you
# understand the implications — it weakens the gate. Default: false (fail-closed).
HEADLESS_ORACLE_SOFT_MODE=false

# Dry-run mode: run the loop end-to-end including quotes but skip signing and
# /execute. Useful for first-time verification. Default: false.
DRY_RUN=false

# Trade log path. Append-only JSONL.
TRADE_LOG_PATH=./trade_log.jsonl
